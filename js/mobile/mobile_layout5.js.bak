  // â”€â”€ DOM Builder â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  function buildDOM() {
    const { config, scenes } = window.TAV_CORE;
    const cats = window.TAV_CORE.getCategories();
    const isMuted = window.TAV_CORE.isMusicMuted;

    // Build carousel (first category default)
    const firstCat = cats[0] || '';
    _activeCategory = firstCat;

    const carouselItems = scenes.map(s => `
      <div class="ml5-carousel-item ml5-interactive" data-action="${s.action}" data-node="${s.action}">
        <div class="ml5-carousel-active-pip"></div>
        <img src="${s.thumb}" alt="${s.title}" onerror="this.src='preview.jpg'">
        <div class="ml5-carousel-item-title">${s.title}</div>
      </div>
    `).join('');

    // Build nav category chips
    const catTabs = cats.map((c, i) =>
      `<button class="ml5-cat-tab${i === 0 ? ' ml5-active' : ''} ml5-interactive" data-cat="${c}">${c}</button>`
    ).join('');

    // Build settings grid
    const settingsBtns = [
      { action: 'hotspots',   icon: I.eye,     label: 'Hotspots' },
      { action: 'autorotate', icon: I.rotate,  label: 'Xoay Tá»± Äá»™ng' },
      { action: 'fullscreen', icon: I.fullscr, label: 'ToĂ n MĂ n HĂ¬nh' },
      { action: 'share',      icon: I.share,   label: 'Chia Sáº»' },
      { action: 'info',       icon: I.info,    label: 'ThĂ´ng Tin' },
      { action: 'region',     icon: I.region,  label: 'LiĂªn Káº¿t VĂ¹ng' },
    ].map(b => `
      <button class="ml5-tool-btn ml5-interactive ml5-ripple-host${b.action === 'hotspots' ? ' ml5-active-tool' : ''}" data-action="${b.action}">
        ${b.icon}<span>${b.label}</span>
      </button>
    `).join('');

    return `
      <!-- â”€â”€ Top Strip: Logo + Compass â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
      <div class="ml5-top-strip ml5-interactive">
        <div class="ml5-compass ml5-interactive" id="ml5-compass" title="Äáº·t láº¡i hÆ°á»›ng nhĂ¬n">
          <svg class="ml5-compass-dial" viewBox="0 0 100 100">
