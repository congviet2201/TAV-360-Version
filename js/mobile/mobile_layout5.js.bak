            <polygon class="ml5-compass-north" points="50,18 58,50 50,60 42,50"/>
            <polygon class="ml5-compass-south" points="50,82 58,50 50,60 42,50"/>
            <circle fill="rgba(124,58,237,0.1)" cx="50" cy="50" r="6"/>
          </svg>
